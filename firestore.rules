rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Yardimci fonksiyonlar ──
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isModerator() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'moderator'];
    }

    // ── Kullanici profilleri ──
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Forum konulari ──
    match /threads/{threadId} {
      allow read: if true;
      allow create: if isAuth();
      // Yazar, mod veya admin guncelleyebilir
      allow update: if isAuth() && (
        resource.data.authorId == request.auth.uid ||
        isModerator()
      );
      // Sadece mod veya admin silebilir
      allow delete: if isModerator();

      // ── Entry'ler (alt koleksiyon) ──
      match /entries/{entryId} {
        allow read: if true;
        allow create: if isAuth();
        // Yazar veya mod/admin guncelleyebilir
        allow update: if isAuth() && (
          resource.data.authorId == request.auth.uid ||
          isModerator()
        );
        // Yazar kendi entry'sini silebilir, mod/admin hepsini
        allow delete: if isAuth() && (
          resource.data.authorId == request.auth.uid ||
          isModerator()
        );
      }
    }

    // ── CollectionGroup sorgulari icin (Profil gecmis entryler) ──
    match /{path=**}/entries/{entryId} {
      allow read: if true;
    }

    // ── Anketler ──
    match /surveys/{surveyId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isModerator();
    }

    // ── Admin loglari ──
    match /admin_logs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── Sozluk ──
    match /dictionary/{termId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Raporlar / Sikayetler ──
    match /reports/{reportId} {
      allow create: if isAuth();
      allow read: if isModerator();
      allow update: if isModerator();
      allow delete: if isAdmin();
    }

    // ── Reklamlar ──
    match /advertisements/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Kullanici Puanları ──
    match /userRatings/{ratingId} {
      allow read: if isAdmin();
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.raterId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ── Mesajlaşma ──
    match /conversations/{convId} {
      allow read: if isAuth() && (request.auth.uid in resource.data.participants);
      allow create: if isAuth();
      allow update: if isAuth() && (request.auth.uid in resource.data.participants);
      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read: if isAuth();
        allow create: if isAuth();
        allow update: if isAuth() && resource.data.senderId == request.auth.uid;
        allow delete: if isAdmin();
      }
    }

    // ── Varsayilan: her seyi engelle ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
