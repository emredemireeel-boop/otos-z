rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Yardimci fonksiyonlar ──
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isModerator() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'moderator'];
    }

    // ── Kullanici profilleri ──
    match /users/{userId} {
      // Herkes profil okuyabilir (username gostermek icin)
      allow read: if true;
      // Sadece kendi profilini guncelleyebilir
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      // Kimse silemesin (sadece admin)
      allow delete: if isAdmin();
    }

    // ── Forum konulari ──
    match /threads/{threadId} {
      // Herkes okuyabilir
      allow read: if true;
      // Giris yapmis kullanici konu olusturabilir
      allow create: if isAuth();
      // Sadece yazar, mod veya admin guncelleyebilir
      allow update: if isAuth() && (
        resource.data.authorId == request.auth.uid ||
        isModerator()
      );
      // Sadece mod veya admin silebilir
      allow delete: if isModerator();

      // ── Entry'ler (alt koleksiyon) ──
      match /entries/{entryId} {
        allow read: if true;
        allow create: if isAuth();
        // Sadece yazar begeni/icerik, mod/admin her sey
        allow update: if isAuth() && (
          resource.data.authorId == request.auth.uid ||
          isModerator()
        );
        allow delete: if isModerator();
      }
    }

    // ── Anketler ──
    match /surveys/{surveyId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isModerator();
    }

    // ── Admin loglari ──
    match /admin_logs/{logId} {
      // Sadece admin okuyup yazabilir
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── Sozluk ──
    match /dictionary/{termId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Raporlar / Sikayetler ──
    match /reports/{reportId} {
      // Herkes rapor olusturabilir
      allow create: if isAuth();
      // Sadece admin/mod okuyup guncelleyebilir
      allow read: if isModerator();
      allow update: if isModerator();
      allow delete: if isAdmin();
    }

    // ── Reklamlar ──
    match /advertisements/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Varsayilan: her seyi engelle ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
