rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Kullanıcılar
    match /users/{userId} {
      allow read: if true;
      // Kendi profilini tamamen yazabilir
      allow write: if request.auth != null && request.auth.uid == userId;
      // Başka kullanıcılar sadece rating alanlarını güncelleyebilir
      allow update: if request.auth != null
        && request.auth.uid != userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ratingTotalScore', 'ratingCount', 'ratingAverage']);
    }
                          
    // Konu Başlıkları (Threads) ve Altındaki Girdiler (Entries)
    match /threads/{threadId} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null;
      
      match /entries/{entryId} {
        allow read: if true;
        allow create, update: if request.auth != null;
        allow delete: if request.auth != null;
      }
    }

    // Sohbetler (Conversations) ve Mesajlar
    match /conversations/{convId} {
      allow read, write: if request.auth != null;
      
      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
    }

    // Bildirimler
    match /notifications/{notifId} {
      allow read, write: if request.auth != null;
    }

    // Anketler (Surveys)
    match /surveys/{surveyId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Karşılaştırmalar (Comparisons)
    match /comparisons/{compId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Araç DNA Kronik Sorunlar & Oylar
    match /vehicle_chronic_issues/{vehicleId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Kullanıcı Puanları
    match /userRatings/{ratingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Raporlar / Şikayetler
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null;
    }

    // Admin Logları
    match /admin_logs/{logId} {
      allow read, write: if request.auth != null;
    }

    // Sözlük
    match /dictionary/{termId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Reklamlar
    match /advertisements/{adId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // İşletme Başvuruları
    match /businesses/{businessId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Etkinlik Önerileri
    match /pending_events/{eventId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Kullanıcı Görevleri (Quests)
    match /userQuests/{questId} {
      allow read: if request.auth != null && request.auth.uid == questId;
      allow write: if request.auth != null && request.auth.uid == questId;
    }

    // Kullanıcı Ayarları (Bakım Takvimi vb.)
    match /user_settings/{settingId} {
      allow read: if request.auth != null && request.auth.uid == settingId;
      allow write: if request.auth != null && request.auth.uid == settingId;
    }

  }
}
